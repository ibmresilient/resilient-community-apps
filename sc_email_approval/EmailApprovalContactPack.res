"uuid": "1e728944-b383-4b85-bd9d-e5b9bc6f729a", "version": 6}, {"activation_type": "manual", "content": {"content_version": 11, "xml": "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"no\"?><definitions xmlns=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:omgdc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:omgdi=\"http://www.omg.org/spec/DD/20100524/DI\" xmlns:resilient=\"http://resilient.ibm.com/bpmn\" xmlns:xsd=\"http://www.w3.org/2001/XMLSchema\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" targetNamespace=\"http://www.camunda.org/test\"><process id=\"playbook_12b133c2_97a0_4fdc_9ee2_32bca9628d36\" isExecutable=\"true\" name=\"playbook_12b133c2_97a0_4fdc_9ee2_32bca9628d36\"><documentation/><startEvent id=\"StartEvent_155asxm\"><outgoing>Flow_1s99adl</outgoing></startEvent><serviceTask id=\"ServiceTask_1\" name=\"Task Utils: Create Custom Task\" resilient:type=\"function\"><extensionElements><resilient:function uuid=\"c4281bd4-d872-4562-b7c8-b0e379aea8ad\">{\"inputs\":{},\"pre_processing_script\":\"import json\\n\\ninputs.incident_id = incident.id\\ntry:\\n  artifact_value = artifact.value\\nexcept:\\n  artifact_value = None\\nif artifact_value:\\n  inputs.task_name = f\\\"Requested approval for artifact: {artifact.type} - {artifact_value}\\\"\\nelse:\\n  inputs.task_name = f\\\"Requested approval for artifact type: '{artifact.type}'\\\"\\n\\n\\ntask_payload = { \\n  \\\"phase_id\\\": {\\n    \\\"name\\\": \\\"Respond\\\" \\n  },\\n  \\\"owner_id\\\": { \\n    \\\"name\\\": principal.name \\n  },\\n  \\\"required\\\": True\\n}\\n\\n  \\nif playbook.inputs.email_approval_expiration:\\n  task_payload['due_date'] = playbook.inputs.email_approval_expiration\\n  \\ninputs.task_utils_payload = json.dumps(task_payload)\",\"pre_processing_script_language\":\"python3\",\"result_name\":\"task_creation\"}</resilient:function></extensionElements><incoming>Flow_1s99adl</incoming><outgoing>Flow